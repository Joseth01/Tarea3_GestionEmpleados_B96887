@model IEnumerable<SistemaDeGestiónDeEmpleados.MODEL.Empleado>

@{
    ViewData["Title"] = "Empleados";
}

<h2 class="mb-4">Gestión de Empleados</h2>

<div class="row mb-3">
    <div class="col-md-6">
        <form method="get" asp-action="Index" class="d-flex">
            <input type="text" name="busqueda" value="@ViewBag.Busqueda" class="form-control me-2" placeholder="Buscar por nombre, apellido o departamento" />
            <button type="submit" class="btn btn-primary">Buscar</button>
        </form>
    </div>

    <div class="col-md-6 text-end">
        <a asp-action="Create" class="btn btn-success">Nuevo Empleado</a>
    </div>
</div>

<div class="mb-2">
    <strong>Total registros:</strong> @ViewBag.TotalRegistros
</div>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Id</th>
            <th>Nombre Completo</th>
            <th>Departamento</th>
            <th>Salario</th>
            <th>Fecha Ingreso</th>
            <th>Estado</th>
            <th class="text-center">Acciones</th>
        </tr>
    </thead>

    <tbody>
        @if (!Model.Any())
        {
            <tr>
                <td colspan="7" class="text-center">
                    No se encontraron registros.
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.NombreCompleto</td>
                    <td>@item.Departamento</td>
                    <td>@item.Salario.ToString("C")</td>
                    <td>@item.FechaIngreso.ToString("dd/MM/yyyy")</td>

                    <td>
                        @if (item.Activo)
                        {
                            <span class="badge bg-success">Activo</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Dado de Baja</span>
                        }
                    </td>

                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                            Editar
                        </a>

                        <form asp-action="ToggleActivo" asp-route-id="@item.Id" method="post" style="display:inline;">
                            <button type="submit" class="btn btn-sm @(item.Activo ? "btn-danger" : "btn-success")">
                                @(item.Activo ? "Dar de Baja" : "Activar")
                            </button>
                        </form>
                    </td>
                </tr>
            }
        }
    </tbody>
</table>

<div class="d-flex justify-content-between align-items-center mt-3">

    <div>
        Página @ViewBag.PaginaActual de @ViewBag.TotalPaginas
    </div>

    <div>
        <a asp-action="Index"
               asp-route-pagina="@(ViewBag.PaginaActual - 1)"
               asp-route-busqueda="@ViewBag.Busqueda"
               class="btn btn-outline-primary @(ViewBag.PaginaActual <= 1 ? "disabled" : "")">
            Anterior
        </a>

        <a asp-action="Index"
               asp-route-pagina="@(ViewBag.PaginaActual + 1)"
               asp-route-busqueda="@ViewBag.Busqueda"
               class="btn btn-outline-primary @(ViewBag.PaginaActual >= ViewBag.TotalPaginas ? "disabled" : "")">
            Siguiente
        </a>
    </div>
</div>